{
  "compilerOptions": {
    "outDir": "build/",
    "target": "es2020",
    "lib": ["esnext"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noEmitOnError": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
