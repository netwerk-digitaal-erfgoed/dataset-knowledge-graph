@prefix nde: <https://data.netwerkdigitaalerfgoed.nl/def/> .

# Overrides for datasets where the dynamic subject filter doesn't apply.
# All other data.bibliotheken.nl datasets get a subject filter dynamically
# using the pattern: ?s schema:mainEntityOfPage/schema:isPartOf <dataset-uri>.

# Datasets with a different predicate path.
<http://data.bibliotheken.nl/id/dataset/rise-alba> nde:subjectFilter "?s <http://xmlns.com/foaf/0.1/isPrimaryTopicOf>/<http://rdfs.org/ns/void#inDataset> <http://data.bibliotheken.nl/id/dataset/rise-alba>" .
<http://data.bibliotheken.nl/id/dataset/rise-centsprenten> nde:subjectFilter "?s <http://schema.org/isPartOf> 'Centsprenten van de Koninklijke Bibliotheek'@nl" .
